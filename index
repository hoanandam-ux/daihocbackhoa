<script>
  function showDay(dayId, btn) {
    document.querySelectorAll('.schedule-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.day-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('day-' + dayId).classList.add('active');
    if(btn) btn.classList.add('active');
  }

  // Rotating quotes
  const quotes = [
    "Mỗi buổi tối Hoan ngồi học là một bước gần hơn đến Bách Khoa.",
    "Không ai thất bại vì cố gắng quá nhiều — chỉ thất bại khi bỏ cuộc.",
    "90 phút tiếng Anh mỗi ngày × 365 ngày = Hoan đỗ Bách Khoa.",
    "Hôm nay khó, ngày mai dễ hơn một chút — và cứ thế tiến lên.",
    "Bách Khoa Hà Nội đang chờ người đủ kiên trì. Hoan có thể là người đó.",
    "Học lúc 10 giờ đêm khi buồn ngủ — đó là lúc bản lĩnh được rèn.",
    "Từ vựng học tối nay, 6 tháng sau xuất hiện trong đề thi. Đừng bỏ qua.",
    "Thành công không phải điều gì to lớn — chỉ là chuỗi ngày nhỏ được giữ vững."
  ];
  let qi = 0;
  function rotateQuote() {
    const el = document.getElementById('quoteText');
    el.style.opacity = '0';
    setTimeout(() => {
      qi = (qi + 1) % quotes.length;
      el.textContent = '"' + quotes[qi] + '"';
      el.style.opacity = '1';
    }, 400);
  }
  document.getElementById('quoteText').style.transition = 'opacity 0.4s';
  setInterval(rotateQuote, 5000);
</script>
